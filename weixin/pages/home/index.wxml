<nav nav-type="search" />
<view class="community-page">
  <view class="community-hero">
    <view>
      <text class="eyebrow">校园社区论坛</text>
      <view class="hero-title">发现同学正在讨论的事</view>
      <view class="hero-desc">图文分享、求助问答、楼中楼回复、话题检索与互动通知统一汇聚。</view>
    </view>
    <view class="hero-stats">
      <view wx:for="{{stats}}" wx:key="label" class="stat-item">
        <text class="stat-value">{{item.value}}</text>
        <text class="stat-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-x class="topic-strip" show-scrollbar="{{false}}">
    <t-tag wx:for="{{hotTopics}}" wx:key="index" class="topic" size="large" theme="primary" variant="light">#{{item}}</t-tag>
  </scroll-view>

  <t-tabs value="{{activeTab}}" bind:change="onTabChange">
    <t-tab-panel wx:for="{{tabs}}" wx:key="item" label="{{item}}" value="{{item}}">
      <view class="post-list">
        <view wx:for="{{posts}}" wx:key="id" class="post-card">
          <image class="post-cover" src="{{item.image}}" mode="aspectFill" />
          <view class="post-body">
            <view class="post-author">
              <t-avatar image="{{item.avatar}}" size="72rpx" />
              <view>
                <view class="author-name">{{item.author}}</view>
                <view class="post-type">{{item.type}} · {{item.views}} 浏览</view>
              </view>
              <t-button class="follow-btn" size="small" theme="light" shape="round">关注</t-button>
            </view>
            <view class="post-title">{{item.title}}</view>
            <view class="post-content">{{item.content}}</view>
            <view class="tag-row">
              <t-tag wx:for="{{item.topics}}" wx:for-item="topic" wx:key="index" size="small" variant="outline">#{{topic}}</t-tag>
            </view>
            <view class="post-actions">
              <t-button size="small" variant="text" icon="thumb-up" data-id="{{item.id}}" bindtap="likePost">{{item.likes}}</t-button>
              <t-button size="small" variant="text" icon="chat" bindtap="sharePost">{{item.comments}}</t-button>
              <t-button size="small" variant="text" icon="star" bindtap="favoritePost">收藏</t-button>
              <t-button size="small" variant="text" icon="share" bindtap="sharePost">分享</t-button>
            </view>
          </view>
        </view>
      </view>
    </t-tab-panel>
  </t-tabs>

  <view class="home-release">
    <t-button theme="primary" size="large" icon="add" shape="round" bindtap="goRelease">发布</t-button>
  </view>
</view>
