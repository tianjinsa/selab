<nav nav-type="search" />
<view class="community-page">
  <view class="community-hero">
    <view>
      <text class="eyebrow">校园社区论坛</text>
      <view class="hero-title">发现同学正在讨论的事</view>
      <view class="hero-desc">图文分享、求助问答、楼中楼回复、话题检索与互动通知统一汇聚。</view>
    </view>
    <view class="hero-stats">
      <view wx:for="{{stats}}" wx:key="label" class="stat-item">
        <text class="stat-value">{{item.value}}</text>
        <text class="stat-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <scroll-view wx:if="{{hotTopics.length}}" scroll-x class="topic-strip" show-scrollbar="{{false}}">
    <t-tag wx:for="{{hotTopics}}" wx:key="index" class="topic" size="large" theme="primary" variant="light">#{{item}}</t-tag>
  </scroll-view>

  <t-tabs value="{{activeTab}}" bind:change="onTabChange">
    <t-tab-panel wx:for="{{tabs}}" wx:key="item" label="{{item}}" value="{{item}}"></t-tab-panel>
  </t-tabs>

  <view wx:if="{{loading}}" class="state-box">
    <t-loading theme="circular" size="48rpx" text="加载帖子中" />
  </view>

  <t-empty wx:elif="{{!filteredPosts.length}}" description="暂无帖子" />

  <view wx:else class="waterfall">
    <view wx:for="{{columns}}" wx:for-item="column" wx:key="index" class="waterfall-column">
      <view wx:for="{{column}}" wx:key="id" class="post-card" data-id="{{item.id}}" bindtap="openDetail">
        <image class="post-cover" style="height: {{item.coverHeight}}rpx;" src="{{item.cover}}" mode="aspectFill" />
        <view class="post-body">
          <view class="post-title">{{item.title}}</view>
          <view class="post-content">{{item.content}}</view>
          <view class="tag-row">
            <t-tag wx:for="{{item.topics}}" wx:for-item="topic" wx:key="index" size="small" variant="outline">#{{topic}}</t-tag>
          </view>
          <view class="post-author">
            <t-avatar image="{{item.avatar}}" size="48rpx" />
            <view class="author-info">
              <view class="author-name">{{item.authorName}}</view>
              <view class="post-type">{{item.type}} · {{item.publishTime}}</view>
            </view>
          </view>
          <view class="post-actions">
            <t-button size="small" variant="text" icon="thumb-up" data-id="{{item.id}}" catchtap="likePost">{{item.likeCount}}</t-button>
            <t-button size="small" variant="text" icon="chat" data-id="{{item.id}}" catchtap="commentPost">{{item.commentCount}}</t-button>
            <t-button size="small" variant="text" icon="star" data-id="{{item.id}}" catchtap="favoritePost"></t-button>
            <t-button size="small" variant="text" icon="share" data-id="{{item.id}}" catchtap="sharePost"></t-button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="home-release">
    <t-button theme="primary" size="large" icon="add" shape="round" bindtap="goRelease">发布</t-button>
  </view>
</view>
