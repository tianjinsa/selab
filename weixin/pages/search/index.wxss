page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #eef3f7;
}

.search-input {
  padding: 16rpx 0;
}

.search-page {
  display: flex;
  flex: 1;
  flex-direction: column;
  min-height: 0;
  box-sizing: border-box;
  width: 100vw;
  height: auto;
  padding: 0 30rpx;
  color: #172033;
  background: #eef3f7;
}

.search-page .t-class__input-container {
  border-radius: 999rpx !important;
}

.search-page .t-search__input {
  font-size: 28rpx !important;
  color: #111827 !important;
}

.search-page .search-wrap {
  margin-top: 24rpx;
}

.market-search-layout {
  display: grid;
  flex: 1;
  grid-template-columns: 172rpx minmax(0, 1fr);
  min-height: 0;
  height: auto;
  margin: 14rpx -30rpx 0;
  border-top: 1rpx solid #d8e2ed;
}

.market-parent-list {
  height: 100%;
  background: #f7fafc;
}

.market-parent-item {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: 0 16rpx 0 24rpx;
  color: #5f6f85;
  font-size: 25rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.market-parent-item.active {
  color: #176b87;
  background: #ffffff;
}

.market-parent-item.active::before {
  position: absolute;
  top: 24rpx;
  bottom: 24rpx;
  left: 0;
  width: 6rpx;
  border-radius: 999rpx;
  background: #176b87;
  content: '';
}

.market-result-list {
  height: 100%;
  padding: 20rpx;
  box-sizing: border-box;
}

.market-child-panel,
.market-result-card,
.empty-market {
  border: 1rpx solid #dbe4ef;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.06);
}

.market-child-panel {
  padding: 20rpx;
  margin-bottom: 18rpx;
}

.market-child-title {
  color: #111827;
  font-size: 27rpx;
  font-weight: 800;
}

.market-child-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.market-child-chip {
  min-width: 104rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  color: #5f6f85;
  background: #f7fafc;
  font-size: 24rpx;
  text-align: center;
  box-sizing: border-box;
}

.market-child-chip.active {
  color: #176b87;
  background: #eef8fb;
  font-weight: 800;
}

.market-result-card {
  display: grid;
  grid-template-columns: 150rpx minmax(0, 1fr);
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding: 16rpx;
}

.market-result-card--text {
  grid-template-columns: minmax(0, 1fr);
  padding: 20rpx;
}

.market-result-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
  background: #d8e2ed;
}

.market-result-main {
  min-width: 0;
}

.market-result-title {
  overflow: hidden;
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.market-result-desc {
  overflow: hidden;
  margin-top: 8rpx;
  color: #5f6f85;
  font-size: 23rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.market-result-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 18rpx;
  color: #5f6f85;
  font-size: 22rpx;
}

.market-result-foot text:first-child {
  color: #d35400;
  font-size: 31rpx;
  font-weight: 900;
}

.empty-market {
  padding: 64rpx 24rpx;
  text-align: center;
}

.empty-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-desc {
  margin-top: 10rpx;
  color: #5f6f85;
  font-size: 24rpx;
}

.search-page .history-wrap {
  margin-bottom: 20px;
}

.search-page .search-header {
  display: flex;
  flex-flow: row nowrap;
  justify-content: space-between;
  align-items: center;
}

.search-page .search-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  line-height: 42rpx;
}

.search-page .search-clear {
  font-size: 30rpx;
  line-height: 32rpx;
  color: #8a94a6;
  font-weight: bold;
}

.search-page .search-content {
  overflow: hidden;
  display: flex;
  flex-flow: row wrap;
  justify-content: flex-start;
  align-items: flex-start;
  margin-top: 24rpx;
}

.search-page .search-item {
  color: #172033;
  font-size: 24rpx;
  line-height: 32rpx;
  font-weight: 400;
  margin-right: 24rpx;
  margin-bottom: 24rpx;
  border-radius: 8rpx;
}

.search-page .hover-history-item {
  position: relative;
  top: 3rpx;
  left: 3rpx;
  box-shadow: 0 0 8rpx rgba(15, 23, 42, 0.08) inset;
}

.add-notes__confirm {
  color: #fa4126 !important;
}

.popular-wrap {
  margin-top: 32rpx;
}

.search-state {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.result-wrap {
  margin-top: 28rpx;
}

.result-item {
  display: grid;
  grid-template-columns: 82rpx 1fr;
  gap: 16rpx;
  align-items: flex-start;
  margin-top: 18rpx;
  padding: 20rpx;
  border: 1rpx solid #dbe4ef;
  border-radius: 18rpx;
  background: #fff;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.06);
}

.result-main {
  min-width: 0;
}

.result-title {
  overflow: hidden;
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-desc {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 8rpx;
  color: #5f6f85;
  font-size: 24rpx;
  line-height: 1.45;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.search-page .search-item .popular-item {
  background: #f7fafc;
}

.search-page .search-item .history-item {
  background: #e5edf5;
}
