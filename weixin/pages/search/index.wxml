<t-navbar title="搜索" left-arrow />
<view class="page search-page">
  <view class="search-input">
    <t-search
      t-class-input-container="t-class__input-container"
      t-class-input="t-search__input"
      value="{{searchValue}}"
      leftIcon="search"
      action="取消"
      shape="round"
      placeholder="请搜索你想要的内容"
      bind:submit="handleSubmit"
      bind:action-click="actionHandle"
      focus
    ></t-search>
  </view>
  <view wx:if="{{marketMode}}" class="market-search-layout">
    <scroll-view scroll-y class="market-parent-list">
      <view
        wx:for="{{marketCategories}}"
        wx:key="name"
        class="market-parent-item {{activeMarketParent === item.name ? 'active' : ''}}"
        data-name="{{item.name}}"
        bindtap="selectMarketParent"
      >
        {{item.name}}
      </view>
    </scroll-view>

    <scroll-view scroll-y class="market-result-list">
      <view wx:if="{{activeMarketChildren.length}}" class="market-child-panel">
        <view class="market-child-title">{{activeMarketParent}} 分类</view>
        <view class="market-child-list">
          <view class="market-child-chip {{!activeMarketChild ? 'active' : ''}}" data-name="" bindtap="selectMarketChild">全部</view>
          <view
            wx:for="{{activeMarketChildren}}"
            wx:key="item"
            class="market-child-chip {{activeMarketChild === item ? 'active' : ''}}"
            data-name="{{item}}"
            bindtap="selectMarketChild"
          >
            {{item}}
          </view>
        </view>
      </view>

      <view wx:if="{{searching}}" class="search-state">
        <t-loading theme="circular" size="44rpx" text="搜索中" />
      </view>

      <view wx:for="{{marketResults}}" wx:key="id" class="market-result-card" data-route="goods" data-id="{{item.id}}" bindtap="openResult">
        <image src="{{item.cover}}" class="market-result-image" mode="aspectFill" />
        <view class="market-result-main">
          <view class="market-result-title">{{item.name}}</view>
          <view class="market-result-desc">{{item.category}} · {{item.condition}} · {{item.location}}</view>
          <view class="market-result-foot">
            <text>¥{{item.price}}</text>
            <text>{{item.sellerName}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{!searching && !marketResults.length}}" class="empty-market">
        <view class="empty-title">暂无匹配商品</view>
        <view class="empty-desc">换个分类或关键词试试。</view>
      </view>
    </scroll-view>
  </view>

  <view wx:else class="search-wrap">
    <view class="history-wrap">
      <view class="search-header">
        <text class="search-title">历史记录</text>
        <t-icon name="delete" size="large" class="search-clear" bind:click="handleClearHistory" />
      </view>
      <view class="search-content">
        <view
          class="search-item"
          hover-class="hover-history-item"
          wx:for="{{historyWords}}"
          bind:tap="handleHistoryTap"
          bindlongpress="deleteCurr"
          data-index="{{index}}"
          wx:key="*this"
        >
          <t-tag class="history-item margin-12" max-width="{{343}}" variant="light">{{item}}</t-tag>
        </view>
      </view>
    </view>
    <view class="popular-wrap">
      <view class="search-header">
        <text class="search-title">搜索发现</text>
      </view>
      <view class="search-content">
        <view
          class="search-item"
          hover-class="hover-history-item"
          wx:for="{{popularWords}}"
          bind:tap="handlePopularTap"
          data-index="{{index}}"
          wx:key="*this"
        >
          <t-tag class="popular-item margin-12" max-width="{{343}}" variant="light" icon="search"> {{item}} </t-tag>
        </view>
      </view>
    </view>

    <view wx:if="{{searching}}" class="search-state">
      <t-loading theme="circular" size="44rpx" text="搜索中" />
    </view>
    <view wx:elif="{{results.length}}" class="result-wrap">
      <view class="search-header">
        <text class="search-title">搜索结果</text>
      </view>
      <view
        wx:for="{{results}}"
        wx:key="id"
        class="result-item"
        data-route="{{item.route}}"
        data-id="{{item.id}}"
        bindtap="openResult"
      >
        <t-tag size="small" theme="primary" variant="light">{{item.type}}</t-tag>
        <view class="result-main">
          <view class="result-title">{{item.title}}</view>
          <view class="result-desc">{{item.desc}}</view>
        </view>
      </view>
    </view>
  </view>

  <t-dialog
    wx:if="{{dialog.showCancelButton}}"
    visible="{{dialogShow}}"
    content="{{dialog.message}}"
    bindconfirm="confirm"
    bind:close="close"
    confirm-btn="确定"
    cancel-btn="取消"
    t-class-confirm="dialog__button-confirm"
    t-class-cancel="dialog__button-cancel"
  />
  <t-dialog
    wx:else
    visible="{{dialogShow}}"
    content="{{dialog.message}}"
    bindconfirm="confirm"
    bind:close="close"
    confirm-btn="确定"
    t-class-confirm="dialog__button-confirm"
    t-class-cancel="dialog__button-cancel"
  />
</view>
