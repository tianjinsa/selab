<t-navbar title="邀请注册" left-arrow />
<scroll-view class="register-scroll" scroll-y type="list">
  <view class="register-page">
    <view wx:if="{{errorText}}" class="error-banner">{{errorText}}</view>

    <view class="register-card">
      <view class="card-title">创建校园账号</view>
      <view class="card-desc">填写邀请码和账号资料即可注册，不需要短信验证码。</view>

      <view class="field">
        <view class="field-label">邀请码</view>
        <input
          class="input"
          placeholder="请输入邀请码"
          value="{{invitationCode}}"
          data-field="invitationCode"
          bindinput="updateField"
          bindblur="onInviteBlur"
        />
        <view class="hint {{checkingInvite ? 'is-checking' : ''}}">{{inviteHint}}</view>
      </view>

      <view class="field">
        <view class="field-label">账号</view>
        <input
          class="input"
          placeholder="用于登录，至少 3 个字符"
          value="{{account}}"
          data-field="account"
          bindinput="updateField"
        />
      </view>

      <view class="field">
        <view class="field-label">昵称</view>
        <input
          class="input"
          placeholder="请输入昵称"
          value="{{nickname}}"
          data-field="nickname"
          bindinput="updateField"
        />
      </view>

      <view class="field-grid">
        <view class="field">
          <view class="field-label">密码</view>
          <input
            class="input"
            password="{{true}}"
            placeholder="至少 6 位"
            value="{{password}}"
            data-field="password"
            bindinput="updateField"
          />
        </view>

        <view class="field">
          <view class="field-label">确认密码</view>
          <input
            class="input"
            password="{{true}}"
            placeholder="再次输入"
            value="{{confirmPassword}}"
            data-field="confirmPassword"
            bindinput="updateField"
          />
        </view>
      </view>

      <view class="field">
        <view class="field-label">学号（可选）</view>
        <input
          class="input"
          placeholder="不填则使用账号"
          value="{{studentNo}}"
          data-field="studentNo"
          bindinput="updateField"
        />
      </view>

      <view class="field">
        <view class="field-label">手机号（可选）</view>
        <input
          class="input"
          type="number"
          placeholder="仅作为联系方式，不做短信验证"
          value="{{phone}}"
          data-field="phone"
          bindinput="updateField"
        />
      </view>

      <button class="primary-btn" loading="{{loading}}" disabled="{{loading}}" bindtap="submitRegister">注册并登录</button>
    </view>
  </view>
</scroll-view>
