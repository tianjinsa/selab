<t-navbar title="账号登录" left-arrow />
<scroll-view class="login-scroll" scroll-y type="list">
  <view class="login-page">
    <view wx:if="{{errorText}}" class="error-banner">{{errorText}}</view>

    <view class="brand-block">
      <view class="brand-mark">校</view>
      <view class="brand-title">校园智慧生活</view>
      <view class="brand-desc">任务互助、二手交易、社区论坛和智能体统一账号登录。</view>
    </view>

    <view class="login-card">
      <view class="card-title">账号密码登录</view>
      <view class="card-desc">可使用学号、手机号或管理员账号登录。</view>

      <view class="field">
        <view class="field-label">账号</view>
        <input
          class="input"
          placeholder="请输入学号 / 手机号 / 账号"
          value="{{account}}"
          bindinput="onAccountInput"
        />
      </view>

      <view class="field">
        <view class="field-label">密码</view>
        <input
          class="input"
          password="{{true}}"
          placeholder="请输入密码"
          value="{{password}}"
          bindinput="onPasswordInput"
        />
      </view>

      <button class="primary-btn" loading="{{loading}}" disabled="{{loading}}" bindtap="submitLogin">登录</button>
    </view>

    <view class="demo-row">
      <view
        wx:for="{{demoAccounts}}"
        wx:key="label"
        class="demo-chip"
        data-index="{{index}}"
        bindtap="useDemoAccount"
      >
        {{item.label}}
      </view>
    </view>

    <view class="register-card" bindtap="goRegister">
      <view>
        <view class="register-title">没有账号？</view>
        <view class="register-desc">使用邀请码创建校园账号，不需要短信验证码。</view>
      </view>
      <t-icon name="chevron-right" size="36rpx" />
    </view>
  </view>
</scroll-view>
