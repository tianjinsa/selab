<t-navbar placeholder="{{true}}" title="发布动态" left-arrow bind:go-back="goBack" />
<view class="page">
  <view class="release-panel">
    <view class="field-block">
      <view class="field-label">标题</view>
      <t-input value="{{form.title}}" data-field="title" placeholder="写一个清晰的标题" borderless bind:change="updateField" />
    </view>

    <view class="field-block">
      <view class="field-label">内容</view>
      <t-textarea
        value="{{form.content}}"
        data-field="content"
        placeholder="分享校园见闻、求助问题或经验建议"
        maxlength="500"
        indicator
        disableDefaultPadding="{{true}}"
        bind:change="updateField"
      />
    </view>

    <view class="field-block">
      <view class="field-label">类型</view>
      <view class="choice-row">
        <t-tag
          wx:for="{{types}}"
          wx:key="index"
          class="choice-tag"
          theme="{{form.type === item ? 'primary' : 'default'}}"
          variant="{{form.type === item ? 'light' : 'outline'}}"
          data-value="{{item}}"
          bindtap="chooseType"
        >
          {{item}}
        </t-tag>
      </view>
    </view>

    <view class="field-block">
      <view class="field-label">话题</view>
      <view class="choice-row">
        <t-tag
          wx:for="{{topics}}"
          wx:key="value"
          class="choice-tag"
          theme="{{item.active ? 'primary' : 'default'}}"
          variant="{{item.active ? 'light' : 'outline'}}"
          data-value="{{item.value}}"
          bindtap="toggleTopic"
        >
          #{{item.value}}
        </t-tag>
      </view>
    </view>

    <view class="field-block">
      <view class="field-label">图片</view>
      <t-upload media-type="{{['image']}}" files="{{originFiles}}" gridConfig="{{gridConfig}}" bind:success="handleSuccess" bind:remove="handleRemove" max="4" />
    </view>
  </view>

  <view class="bottom-actions">
    <t-button theme="primary" size="large" icon="upload" loading="{{submitting}}" block bindtap="submit">发布</t-button>
  </view>
</view>
