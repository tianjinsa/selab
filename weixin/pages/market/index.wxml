<nav title-text="二手市场" />
<view class="market-page">
  <view class="market-toolbar">
    <view>
      <text class="eyebrow">校园担保交易</text>
      <view class="page-title">二手市场工作台</view>
    </view>
    <t-button theme="primary" icon="add" shape="round" bindtap="publishGoods">发布闲置</t-button>
  </view>

  <view class="metric-row">
    <view wx:for="{{metrics}}" wx:key="label" class="metric">
      <text>{{item.label}}</text>
      <strong>{{item.value}}</strong>
    </view>
  </view>

  <view class="search-panel">
    <t-search placeholder="搜索商品、分类或交易地点" value="{{keyword}}" bind:change="onSearch" />
    <scroll-view scroll-x class="category-strip" show-scrollbar="{{false}}">
      <t-tag
        wx:for="{{categories}}"
        wx:key="index"
        class="category"
        size="large"
        theme="{{activeCategory === item ? 'primary' : 'default'}}"
        variant="{{activeCategory === item ? 'dark' : 'light'}}"
        data-name="{{item}}"
        bindtap="selectCategory"
      >
        {{item}}
      </t-tag>
    </scroll-view>
  </view>

  <view wx:if="{{featured}}" class="featured-card" data-id="{{featured.id}}" bindtap="openDetail">
    <image src="{{featured.cover}}" class="featured-image" mode="aspectFill" />
    <view class="featured-info">
      <t-tag size="small" theme="success" variant="light">信用 {{featured.sellerCredit}}</t-tag>
      <view class="featured-name">{{featured.name}}</view>
      <view class="featured-desc">{{featured.condition}} · {{featured.tradeMode}} · {{featured.location}}</view>
      <view class="featured-bottom">
        <text>¥{{featured.price}}</text>
        <t-button size="small" theme="primary" catchtap="createOrder" data-id="{{featured.id}}" data-name="{{featured.name}}">下单</t-button>
      </view>
    </view>
  </view>

  <view class="section-title">
    <text>全部商品</text>
    <text>{{filteredGoods.length}} 件</text>
  </view>

  <view class="goods-list">
    <view wx:for="{{filteredGoods}}" wx:key="id" class="goods-row" data-id="{{item.id}}" bindtap="openDetail">
      <image src="{{item.cover}}" class="goods-image" mode="aspectFill" />
      <view class="goods-main">
        <view class="goods-title">{{item.name}}</view>
        <view class="goods-meta">{{item.category}} · {{item.condition}} · {{item.tradeMode}}</view>
        <view class="seller-row">
          <t-tag size="small" theme="success" variant="light">信用 {{item.sellerCredit}}</t-tag>
          <text>{{item.sellerName}} · {{item.location}}</text>
        </view>
        <view class="goods-stats">{{item.views}} 浏览 · {{item.consults}} 次咨询 · {{item.status}}</view>
        <view class="goods-actions">
          <text class="price">¥{{item.price}}</text>
          <t-button size="small" variant="text" icon="star" data-id="{{item.id}}" catchtap="favoriteGoods">收藏</t-button>
          <t-button
            size="small"
            theme="light"
            icon="chat"
            catchtap="consultSeller"
            data-seller-id="{{item.seller.id}}"
            data-goods-id="{{item.id}}"
            data-name="{{item.name}}"
          >咨询</t-button>
          <t-button size="small" theme="primary" catchtap="createOrder" data-id="{{item.id}}" data-name="{{item.name}}">下单</t-button>
        </view>
      </view>
    </view>
  </view>
</view>
