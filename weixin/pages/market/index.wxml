<nav title-text="二手市场" />
<view class="market-page">
  <view class="search-panel">
    <view class="market-search-entry" bindtap="openSearch">
      <t-icon name="search" size="34rpx" />
      <text>搜索商品、分类或交易地点</text>
    </view>
    <t-button theme="primary" variant="light" icon="view-list" bindtap="openCategoryPage">全部分类</t-button>
  </view>

  <view class="mine-panel">
    <view class="mine-panel__head">
      <view>
        <view class="mine-panel__title">我的交易</view>
        <view class="mine-panel__desc">求购、发布和收藏集中管理</view>
      </view>
      <t-button size="small" theme="light" shape="round" bindtap="openMine" data-tab="requested">查看全部</t-button>
    </view>
    <view class="mine-summary">
      <view wx:for="{{mineSummary}}" wx:key="tab" class="mine-summary__item" data-tab="{{item.tab}}" bindtap="openMine">
        <t-icon name="{{item.icon}}" size="34rpx" />
        <view class="mine-summary__value">{{item.value}}</view>
        <view class="mine-summary__label">{{item.label}}</view>
      </view>
    </view>
  </view>

  <view class="section-title">
    <text>全部商品</text>
    <text>{{filteredGoods.length}} 件</text>
  </view>

  <view wx:if="{{loading}}" class="state-box">
    <t-loading theme="circular" size="48rpx" text="加载商品中" />
  </view>

  <view wx:else class="goods-list">
    <view wx:for="{{filteredGoods}}" wx:key="id" class="goods-row {{item.cover ? '' : 'goods-row--text'}}" data-id="{{item.id}}" bindtap="openDetail">
      <image wx:if="{{item.cover}}" src="{{item.cover}}" class="goods-image" mode="aspectFill" />
      <view class="goods-main">
        <view class="goods-title">{{item.name}}</view>
        <view class="goods-meta">{{item.category}} · {{item.condition}} · {{item.tradeMode}}</view>
        <view class="seller-row">
          <t-tag size="small" theme="success" variant="light">信用 {{item.sellerCredit}}</t-tag>
          <text>{{item.sellerName}} · {{item.location}}</text>
        </view>
        <view class="goods-stats">{{item.views}} 浏览 · {{item.consults}} 次咨询 · {{item.status}}</view>
        <view class="goods-actions">
          <text class="price">¥{{item.price}}</text>
          <view class="goods-action-buttons">
            <t-button
              size="small"
              theme="{{item.favorited ? 'primary' : 'default'}}"
              variant="{{item.favorited ? 'light' : 'text'}}"
              icon="star"
              data-id="{{item.id}}"
              catchtap="favoriteGoods"
            >{{item.favorited ? '已收藏' : '收藏'}}</t-button>
            <t-button
              size="small"
              theme="light"
              icon="chat"
              catchtap="consultSeller"
              data-seller-id="{{item.seller.id}}"
              data-goods-id="{{item.id}}"
              data-name="{{item.name}}"
            >咨询</t-button>
            <t-button size="small" theme="primary" catchtap="createOrder" data-id="{{item.id}}" data-name="{{item.name}}">求购</t-button>
          </view>
        </view>
      </view>
    </view>
    <view wx:if="{{!filteredGoods.length && !loading}}" class="empty-state">
      <view class="empty-title">暂无在售商品</view>
      <view class="empty-desc">稍后再看看，或先发布你的闲置。</view>
    </view>
  </view>

  <view class="market-release">
    <t-button theme="primary" size="large" icon="add" shape="round" bindtap="publishGoods">发布闲置</t-button>
  </view>
</view>
