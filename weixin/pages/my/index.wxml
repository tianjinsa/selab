<view class="my-page">
  <image class="nav-bg" src="/static/bg_navbar.png" />
  <nav title-text="我的" />

  <view class="profile-panel">
    <view class="profile-row">
      <t-avatar image="{{user.avatar}}" size="128rpx" />
      <view class="profile-main">
        <view class="name-row">
          <text class="nickname">{{user.nickname}}</text>
          <t-tag theme="success" variant="light">信用 {{user.creditLevel}}</t-tag>
        </view>
        <view class="profile-meta">学号 {{user.studentNo}} · {{user.contact}}</view>
        <view class="verified">校园身份已校验 · 全平台单点登录</view>
      </view>
      <t-icon name="edit" size="42rpx" bindtap="onEditProfile" />
    </view>
    <view class="stat-grid">
      <view wx:for="{{stats}}" wx:key="label" class="stat-item">
        <text class="stat-value">{{item.value}}</text>
        <text class="stat-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="message-panel" bindtap="onOpenMessage">
    <view>
      <view class="panel-title">统一消息中心</view>
      <view class="panel-desc">私信、报名、评论、点赞、交易和系统公告都在这里汇聚。</view>
    </view>
    <t-badge count="{{unreadCount}}">
      <t-icon name="chat" size="52rpx" color="#176b87" />
    </t-badge>
  </view>

  <view class="section-title">通知摘要</view>
  <view class="notice-list">
    <view wx:for="{{notifications}}" wx:key="id" class="notice-row {{item.unread ? 'unread' : ''}}">
      <view>
        <view class="notice-title">{{item.title}}</view>
        <view class="notice-meta">{{item.type}} · {{item.time}}</view>
      </view>
      <view wx:if="{{item.unread}}" class="dot"></view>
    </view>
  </view>

  <view class="section-title">我的服务</view>
  <view class="service-grid">
    <view wx:for="{{services}}" wx:key="title" class="service-card {{item.color}}" data-action="{{item.action}}" bindtap="onServiceTap">
      <t-icon name="{{item.icon}}" size="42rpx" />
      <view class="service-title">{{item.title}}</view>
      <view class="service-desc">{{item.desc}}</view>
    </view>
  </view>

  <view class="section-title">账号中心</view>
  <t-cell-group theme="card">
    <t-cell
      wx:for="{{securityItems}}"
      wx:key="title"
      title="{{item.title}}"
      description="{{item.desc}}"
      leftIcon="{{item.icon}}"
      arrow
      hover
      data-action="{{item.action}}"
      bindclick="onSecurityTap"
    />
  </t-cell-group>
</view>
