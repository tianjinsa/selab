<view class="agent-chat">
  <view class="chat-header">
    <view class="title-row" style="padding-top: {{statusHeight}}px; padding-right: {{headerRightInset}}px;">
      <view class="title-block">
        <view class="page-title">智能体</view>
        <view class="session-title">{{activeAgent.title}} · {{sessionTitle}}</view>
      </view>
    </view>
    <view class="header-actions">
      <t-button class="tool-btn" size="small" theme="light" icon="chat" shape="round" bindtap="openHistory">历史</t-button>
      <t-button class="tool-btn" size="small" theme="light" icon="add" shape="round" bindtap="newConversation">新建</t-button>
      <t-button class="tool-btn" size="small" theme="primary" icon="service" shape="round" bindtap="openAgentSwitcher">智能体</t-button>
    </view>
  </view>

  <scroll-view class="message-list" scroll-y scroll-into-view="{{anchor}}">
    <view class="agent-strip">
      <view class="agent-badge">{{activeAgent.badge}}</view>
      <view>
        <view class="agent-name">{{activeAgent.title}}</view>
        <view class="agent-desc">{{activeAgent.desc}}</view>
      </view>
    </view>

    <view wx:for="{{messages}}" wx:key="id" class="message-row {{item.role}}">
      <view wx:if="{{item.role === 'assistant'}}" class="avatar">{{activeAgent.badge}}</view>
      <view class="bubble">
        <view class="message-text">{{item.text}}</view>
        <view wx:if="{{item.source}}" class="source-row">
          <t-tag size="small" theme="primary" variant="light">{{item.tool}}</t-tag>
          <text>{{item.source}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{loading}}" class="message-row assistant">
      <view class="avatar">{{activeAgent.badge}}</view>
      <view class="bubble typing">
        <t-loading theme="dots" size="40rpx" />
      </view>
    </view>
    <view id="bottom" />
  </scroll-view>

  <view class="composer">
    <textarea
      class="composer-input"
      value="{{input}}"
      placeholder="输入校园问题或平台操作需求"
      auto-height
      maxlength="500"
      cursor-spacing="24"
      bindinput="onInput"
    />
    <t-button class="send-btn" theme="primary" shape="round" icon="send" loading="{{loading}}" disabled="{{!input}}" bindtap="sendQuestion">发送</t-button>
  </view>

  <t-drawer
    visible="{{historyVisible}}"
    title="历史对话"
    placement="left"
    items="{{historyItems}}"
    bind:item-click="selectSession"
    bind:close="closeHistory"
  >
    <view wx:if="{{!historyItems.length}}" class="drawer-empty">暂无历史对话</view>
  </t-drawer>

  <t-drawer
    visible="{{agentVisible}}"
    title="切换智能体"
    placement="right"
    items="{{agentItems}}"
    bind:item-click="selectAgent"
    bind:close="closeAgentSwitcher"
  />
</view>
