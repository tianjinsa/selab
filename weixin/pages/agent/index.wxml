<view class="agent-chat">
  <view class="chat-header">
    <view class="phone-nav" style="padding-top: {{statusHeight}}px; padding-right: {{headerRightInset}}px;">
      <view class="nav-icon" bindtap="goMessageCenter">
        <t-icon name="chat" size="34rpx" />
      </view>
      <view class="nav-title">{{activeAgent.title}}</view>
    </view>

    <view class="session-tools" style="padding-right: {{headerRightInset}}px;">
      <view class="menu-button" bindtap="openHistory">
        <t-icon name="menu" size="42rpx" />
      </view>
      <view class="session-copy">
        <view class="session-name">{{sessionTitle || '新会话'}}</view>
        <view class="session-status">
          <text class="status-dot"></text>
          <text>{{activeAgent.title}} · 准备就绪</text>
        </view>
      </view>
      <view class="agent-button" bindtap="openAgentSwitcher">
        <t-icon name="service" size="36rpx" />
      </view>
      <view class="new-button" bindtap="newConversation">
        <t-icon name="add" size="38rpx" />
      </view>
    </view>
  </view>

  <scroll-view class="message-list" scroll-y scroll-into-view="{{anchor}}">
    <view wx:if="{{isEmptyConversation}}" class="empty-card">
      <view class="ai-mark">AI</view>
      <view class="empty-title">从论文问题开始</view>
      <view class="empty-desc">输入一个研究、写作或任务问题，AI 会在当前会话中回复。</view>
      <view class="quick-list">
        <view
          wx:for="{{quickPrompts}}"
          wx:key="item"
          class="quick-pill"
          data-prompt="{{item}}"
          bindtap="useQuickPrompt"
        >
          {{item}}
        </view>
      </view>
    </view>

    <block wx:else>
      <view wx:for="{{messages}}" wx:key="id" wx:if="{{item.id !== 'welcome'}}" class="message-row {{item.role}}">
        <view wx:if="{{item.role === 'assistant'}}" class="avatar">{{activeAgent.badge}}</view>
        <view class="bubble">
          <view class="message-text">{{item.text}}</view>
          <view wx:if="{{item.source}}" class="source-row">
            <t-tag size="small" theme="primary" variant="light">{{item.tool}}</t-tag>
            <text>{{item.source}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{loading}}" class="message-row assistant">
        <view class="avatar">{{activeAgent.badge}}</view>
        <view class="bubble typing">
          <t-loading theme="dots" size="40rpx" />
        </view>
      </view>
    </block>
    <view id="bottom" />
  </scroll-view>

  <view class="composer">
    <view class="composer-shell">
      <textarea
        class="composer-input"
        value="{{input}}"
        placeholder="输入论文、学习或任务问题..."
        maxlength="500"
        cursor-spacing="24"
        bindinput="onInput"
      />
      <view class="send-action {{input && !loading ? 'is-ready' : ''}}" bindtap="sendQuestion">
        {{loading ? '发送中' : '发送'}}
      </view>
    </view>
  </view>

  <view wx:if="{{historyVisible}}" class="history-layer">
    <view class="layer-mask" bindtap="closeHistory"></view>
    <view class="history-panel" style="padding-top: {{statusHeight}}px;" catchtap="stopTap">
      <view class="panel-head">
        <view>
          <view class="panel-title">历史对话</view>
          <view class="panel-desc">继续上次的智能体问答</view>
        </view>
        <view class="panel-close" bindtap="closeHistory">
          <t-icon name="close" size="36rpx" />
        </view>
      </view>

      <view wx:if="{{!historyItems.length}}" class="history-empty">
        <view class="empty-icon">
          <t-icon name="chat-bubble-history" size="56rpx" />
        </view>
        <view class="empty-main">暂无历史对话</view>
        <view class="empty-sub">发送第一条消息后，会话会自动记录在这里。</view>
      </view>

      <scroll-view wx:else scroll-y class="history-list">
        <view wx:for="{{historyItems}}" wx:key="sessionId" class="history-card" data-session-id="{{item.sessionId}}" bindtap="selectSession">
          <view class="history-main">
            <view class="history-title">{{item.title}}</view>
            <view class="history-preview">{{item.preview}}</view>
            <view class="history-time">{{item.updatedAt}}</view>
          </view>
          <view class="history-delete" data-session-id="{{item.sessionId}}" catchtap="deleteSession">
            <t-icon name="delete" size="34rpx" />
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view wx:if="{{agentVisible}}" class="agent-switch-layer" style="background: {{activeAgent.softColor}};">
    <view class="agent-switch-mask" bindtap="closeAgentSwitcher"></view>
    <view class="agent-switch-panel" style="padding-top: {{statusHeight}}px;" catchtap="stopTap">
      <view class="panel-head">
        <view>
          <view class="panel-title">切换智能体</view>
          <view class="panel-desc">左右滑动，选择不同提示词背景</view>
        </view>
        <view class="panel-close" bindtap="closeAgentSwitcher">
          <t-icon name="close" size="36rpx" />
        </view>
      </view>

      <swiper
        class="agent-swiper"
        current="{{agentIndex}}"
        previous-margin="52rpx"
        next-margin="52rpx"
        duration="280"
        bindchange="onAgentSwiperChange"
      >
        <swiper-item wx:for="{{agents}}" wx:key="key">
          <view
            class="agent-card {{agentIndex === index ? 'is-active' : ''}}"
            style="background: {{item.softColor}}; border-color: {{item.borderColor}};"
            data-index="{{index}}"
            bindtap="selectAgentCard"
          >
            <view class="agent-card-icon" style="background: {{item.accent}};">{{item.badge}}</view>
            <view class="agent-card-title">{{item.title}}</view>
            <view class="agent-card-desc">{{item.desc}}</view>
            <view class="agent-card-prompt">{{item.greeting}}</view>
          </view>
        </swiper-item>
      </swiper>

      <view class="agent-dots">
        <view wx:for="{{agents}}" wx:key="key" class="agent-dot {{agentIndex === index ? 'active' : ''}}"></view>
      </view>

      <t-button theme="primary" size="large" block shape="round" bindtap="closeAgentSwitcher">使用 {{activeAgent.title}}</t-button>
    </view>
  </view>
</view>
