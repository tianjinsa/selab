<view wx:if="{{transitionState !== 'idle'}}" class="tab-transition-layer state-{{transitionState}} direction-{{transitionDirection}}">
  <view class="transition-panel">
    <view wx:if="{{transitionState === 'source'}}" class="transition-spinner"></view>
    <view wx:else class="transition-done">{{transitionState === 'failed' ? '!' : '✓'}}</view>
    <view class="transition-bar"></view>
    <view class="transition-text">{{transitionText}}</view>
  </view>
</view>

<view class="custom-tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="value"
    class="tab-item {{item.value === value ? 'is-active' : ''}} {{pressedValue === item.value ? 'is-pressing' : ''}}"
    data-value="{{item.value}}"
    aria-role="button"
    aria-label="{{item.label}}"
    bindtouchstart="handlePressStart"
    bindtouchcancel="clearPress"
    bindtouchend="clearPress"
    bindtap="handleTap"
  >
    <view class="tab-icon-shell {{item.isManageEntry ? 'is-manage' : ''}}">
      <view class="tab-icon-stack {{item.isManageEntry ? 'is-manage' : ''}}">
        <t-icon class="tab-icon base-icon" name="{{item.icon}}" size="40rpx" />
        <t-icon class="tab-icon gear-icon" name="setting" size="40rpx" />
      </view>
      <view wx:if="{{item.value === 'my' && unreadNum}}" class="tab-badge">{{unreadNum > 99 ? '99+' : unreadNum}}</view>
    </view>
    <view class="tab-label">{{item.label}}</view>
  </view>
</view>
